# mcelog configuration written by Chef.  Do not hand edit

<%= "cpu=#{@cpu}" if @cpu -%>
<%= "cpumhz=#{@cpumhz}" if @cpumhz -%>
logfile = <%= @logfile %>
raw = <%= @raw %>
filter = <%= @filter %>
filter-memory-errors = <%= @filter_memory_errors %>
syslog = <%= @syslog %>
syslog-error = <%= @syslog_error %>
dmi = <%= @dmi %>
run-credentials-user = <%= @run_credentials_user %>
run-credentials-group = <%= @run_credentials_group %>

[server]
client-user = <%= @client_user %>
client-group = <%= @client_group %>

[dimm]
dimm-tracking-enabled = <%= @dimm_tracking_enabled %>
dmi-prepopulate = <%= @dmi_prepopulate %>
uc-error-threshold = <%= @uc_error_threshold %>
ce-error-threshold = <%= @ce_error_threshold %>

[socket]
socket-tracking-enabled = <%= @socket_tracking_enabled %>
mem-uc-error-threshold = <%= @mem_uc_error_threshold %>
mem-ce-error-trigger = <%= @mem_ce_error_trigger %>
mem-ce-error-threshold = <%= @mem_ce_error_threshold %>
mem-ce-error-log = <%= @mem_ce_error_log %>

[cache]
cache-threshold-trigger = <%= @cache_threshold_trigger %>
cache-threshold-log = <%= @cache_threshold_log %>

[page]
memory-ce-threshold = <%= @memory_ce_threshold %>
memory-ce-log = <%= @memory_ce_log %>
memory-ce-action = <%= @memory_ce_action %>

[trigger]
children-max = <%= @children_max %>
directory = <%= @trigger_directory %>
